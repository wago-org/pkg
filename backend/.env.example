# Port the HTTP server listens on.
PORT=8787

# GitHub OAuth app credentials (https://github.com/settings/developers).
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# The backend's own OAuth callback URL. Must exactly match the "Authorization
# callback URL" configured on the GitHub OAuth app.
OAUTH_REDIRECT_URL=http://localhost:8787/auth/github/callback

# Where to send the browser after login; also the allowed CORS origin.
FRONTEND_URL=http://localhost:8000

# HMAC key used to sign session cookies. If empty, an ephemeral key is generated
# at startup (sessions will not survive a restart). REQUIRED in production.
SESSION_SECRET=change-me-to-a-long-random-string

# wago-registry/v1 seed file. Imported into the store once, on first run when the
# store is empty. Not modified by the backend.
PACKAGES_FILE=./data/packages.json

# Read/write JSON store for the whole registry (packages, users, stars, reviews,
# votes, comments, installs). Created if missing.
STORE_FILE=./data/store.json

# When true, cookies are not marked Secure so localhost over http works.
DEV_MODE=true

# Optional: cookie Domain for production (e.g. .wago.sh). Leave empty in dev.
COOKIE_DOMAIN=
