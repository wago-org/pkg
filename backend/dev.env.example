# ── Local development ────────────────────────────────────────────────────────
# Loaded by `make dev` / `make api` (which run from the backend/ directory).
# Copy to dev.env (`make env`) and fill in the GitHub creds. dev.env is
# git-ignored; this .example is the committed template.

PORT=8787

# GitHub OAuth app for LOCAL dev.
# Register at https://github.com/settings/developers with callback URL:
#   http://localhost:8787/auth/github/callback
# Leave blank to browse in local-demo mode (sign-in faked in the browser).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must match the OAuth app's "Authorization callback URL" exactly.
OAUTH_REDIRECT_URL=http://localhost:8787/auth/github/callback

# Where the browser is sent after login; also the allowed CORS origin.
FRONTEND_URL=http://localhost:8000

# Any non-empty string works locally; sessions reset when it changes.
SESSION_SECRET=dev-only-secret

# Seed index (relative to backend/) and the read/write store.
PACKAGES_FILE=../data/packages.json
STORE_FILE=data/store.json

# http on localhost → cookies must NOT be Secure.
DEV_MODE=true

# No cross-subdomain cookie needed locally.
COOKIE_DOMAIN=
